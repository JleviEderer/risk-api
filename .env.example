# Required
WALLET_ADDRESS=0x13580b9C6A9AfBfE4C739e74136C1dA174dB9891

# Optional — defaults shown
BASE_RPC_URL=https://mainnet.base.org
FACILITATOR_URL=https://api.cdp.coinbase.com/platform/v2/x402
NETWORK=eip155:8453
PRICE=$0.10
PUBLIC_URL=https://augurrisk.com

# ERC-8004 agent registration (optional)
ERC8004_AGENT_ID=19074

# Basescan API key for deployer reputation checks (optional — degrades gracefully)
BASESCAN_API_KEY=

# CDP facilitator auth (optional — for Coinbase Bazaar indexing)
# Key file auto-loaded from ~/.config/risk-api/cdp_api_key.json if env vars unset
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# x402.jobs marketplace API key (optional — for registering/updating listings)
# Get one at: https://www.x402.jobs/dashboard/api-keys
X402_JOBS_API_KEY=
